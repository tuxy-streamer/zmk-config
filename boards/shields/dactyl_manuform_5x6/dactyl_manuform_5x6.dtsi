#include <dt-bindings/zmk/matrix_transform.h>
#include "dactyl_manuform_5x6-layouts.dtsi"
#include <zephyr/dt-bindings/spi/spi.h>
#include <zephyr/dt-bindings/input/input-event-codes.h>

/* https://forum.seeedstudio.com/t/xiao-nrf52840-plus/294262/7
*/
nice_view_spi: &spi0 { };

/ {
    trackball_listener {
        compatible = "zmk,input-listener";
        device = <&trackball>;
        input-processors = <&zip_temp_layer 4 400>; // auto-mouse temp layer for 0.4 secs
    };

    /omit-if-no-ref/ zip_temp_layer: zip_temp_layer {
        compatible = "zmk,input-processor-temp-layer";
        #input-processor-cells = <2>;
        require-prior-idle-ms = <500>; // Only activate if no key presses for 0.5 seconds
    };
};

&pinctrl {
    spi0_default: spi0_default {
        group1 {
            psels = <NRF_PSEL(SPIM_SCK, 0, 17)>,  /* P0.17 */
                    <NRF_PSEL(SPIM_MOSI, 0, 22)>, /* P0.22 */
                    <NRF_PSEL(SPIM_MISO, 0, 20)>; /* P0.20 */
        };
    };

    spi0_sleep: spi0_sleep {
        group1 {
            psels = <NRF_PSEL(SPIM_SCK, 0, 17)>,
                    <NRF_PSEL(SPIM_MOSI, 0, 22)>,
                    <NRF_PSEL(SPIM_MISO, 0, 20)>;
            low-power-enable;
        };
    };
};

&spi0 {
    status = "okay";
    pinctrl-0 = <&spi0_default>;
    pinctrl-1 = <&spi0_sleep>;
    pinctrl-names = "default", "sleep";
    label = "spi0";
    
    /* Chip Select on P0.24 - display, P1.00 - PMW3389 */
    cs-gpios = <&gpio0 24 GPIO_ACTIVE_HIGH>   /* Index 0: Display */
            , <&gpio1 00 GPIO_ACTIVE_LOW>;    /* Index 1: Trackball, ative_low is typical for pixart */

    trackball: trackball@1 {
		status = "okay";
		compatible = "pixart,pmw33xx";
 		reg = <1>;
		spi-max-frequency = <1000000>; // | SPI_CPOL | SPI_CPHA
		// pmw33xx driver parameters
		motswk-gpios = <&gpio0 11 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>;
        //reset-gpios = <&gpio0 24 GPIO_ACTIVE_LOW| GPIO_PULL_UP>; // SPI Mode 3, specific for pmw3360
        //spi-cpol;
        //spi-cpha;
		cpi = <600>;
	};
};

// virtual usb logging https://zmk.dev/docs/development/usb-logging#adding-usb-logging-to-a-board
&zephyr_udc0 {
    status = "okay";
    cdc_acm_uart0: cdc_acm_uart0 {
        compatible = "zephyr,cdc-acm-uart";
    };
};

/ {
     chosen {
        zmk,battery = &vbatt;
        zmk,kscan = &kscan0;
        zmk,matrix_transform = &default_transform;
        zephyr,console = &cdc_acm_uart0;
        zephyr,shell-uart = &cdc_acm_uart0;
    };
    vbatt: vbatt {
        compatible = "zmk,battery-nrf-vddh";
    };
    default_transform: keymap_transform_0 {
        compatible = "zmk,matrix-transform";
        columns = <12>;
        rows = <6>;
// | SW1  | SW2  | SW3  | SW4  | SW5  | SW6  |                 | SW6 | SW5  | SW4  | SW3  | SW2  | SW1 |
// | SW7  | SW8  | SW9  | SW10 | SW11 | SW12 |                 | SW12 | SW11 | SW10 | SW9 | SW8 | SW7 |
// | SW13 | SW14 | SW15 | SW16 | SW17 | SW18 |                 | SW18 | SW17 | SW16 | SW15 | SW14 | SW13 |
// | SW19 | SW20 | SW21 | SW22 | SW23 | SW24 |                 | SW24 | SW23 | SW22 | SW21 | SW20 | SW19 |
//               | SW25 | SW26 |                                             | SW26 | SW25 |
//                             | SW27 | SW28 |                 | SW28 | SW27 |
//                                    | SW29 | SW30 |   | SW30 | SW29 |
//                                    | SW31 | SW32 |   | SW32 | SW31 |
        map = <
RC(0,0) RC(0,1) RC(0,2) RC(0,3) RC(0,4) RC(0,5)                   RC(0,11) RC(0,10) RC(0,9) RC(0,8) RC(0,7) RC(0,6)
RC(1,0) RC(1,1) RC(1,2) RC(1,3) RC(1,4) RC(1,5)                   RC(1,11) RC(1,10) RC(1,9) RC(1,8) RC(1,7) RC(1,6)
RC(2,0) RC(2,1) RC(2,2) RC(2,3) RC(2,4) RC(2,5)                   RC(2,11) RC(2,10) RC(2,9) RC(2,8) RC(2,7) RC(2,6)
RC(3,0) RC(3,1) RC(3,2) RC(3,3) RC(3,4) RC(3,5)                   RC(3,11) RC(3,10) RC(3,9) RC(3,8) RC(3,7) RC(3,6)
                RC(4,2) RC(4,3)                                                     RC(4,9) RC(4,8)
                                        RC(4,0) RC(4,1)    RC(4,7) RC(4,6)
                                        RC(5,4) RC(4,4)    RC(4,10) RC(5,11)
                                        RC(5,5) RC(4,5)    RC(4,11) RC(5,10)
        >;
    };

    kscan0: kscan {
        compatible = "zmk,kscan-gpio-matrix";
        diode-direction = "col2row";
        wakeup-source;
        row-gpios
            = <&gpio1 11 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
            , <&gpio1 13 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
            , <&gpio1 15 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
            , <&gpio0  2 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
            , <&gpio0 29 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
            , <&gpio0 31 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
            ;
    };
};

&physical_layout0 {
    kscan = <&kscan0>;
    transform = <&default_transform>;
};